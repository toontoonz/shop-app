# Copy this file to `.env.local` for local development.
# `.env.local` is gitignored — never commit secrets.

# PostgreSQL connection string. Matches docker-compose.yml defaults (port 5433 to avoid conflict with other projects).
DATABASE_URL="postgresql://shopapp:shopapp@localhost:5433/shopapp?schema=public"

# Auth.js v5 cookie/session secret. Generate via `openssl rand -hex 32`.
NEXTAUTH_SECRET="replace-me-with-32-byte-random-hex"

# Base URL Auth.js uses for callbacks (must match the URL you visit during dev).
NEXTAUTH_URL="http://localhost:3000"

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL="debug"

# Bearer token required by /api/cron/* endpoints (Vercel Cron sends this header).
CRON_SECRET="replace-me-with-random-string"

# Password set on the demo seller account by `pnpm db:seed`. Dev-only.
DEMO_SELLER_PASSWORD="demo1234"
